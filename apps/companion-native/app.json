{
  "expo": {
    "name": "Axon Online",
    "owner": "king-prod",
    "slug": "axon-online",
    "scheme": "axononline",
    "version": "0.1.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "orientation": "portrait",
    "icon": "../../ui/icons/icon-512.png",
    "splash": {
      "image": "../../ui/icons/icon-512.png",
      "resizeMode": "contain",
      "backgroundColor": "#08111f"
    },
    "plugins": [
      "expo-secure-store",
      "expo-dev-client",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Axon Online to capture your voice so it can transcribe and run mobile commands."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "za.org.edudashpro.axononline"
    },
    "android": {
      "package": "za.org.edudashpro.axononline",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "../../ui/icons/icon-512.png",
        "backgroundColor": "#08111f"
      }
    },
    "extra": {
      "apiBaseUrl": "http://127.0.0.1:7734",
      "defaultWorkspaceId": null,
      "eas": {
        "projectId": "2dcf2ff8-d911-42a8-bcd7-8bc9203ef46c"
      }
    }
  }
}
